# Server
PORT=4000
ALLOWED_ORIGIN=http://localhost:5173

# MongoDB (must be a replica set — Atlas is one by default; see server/README.md for local dev)
MONGODB_URI=mongodb://localhost:27017/abopay?replicaSet=rs0

# Firebase Admin (used ONLY to verify ID tokens — no Firestore access from this server)
# Paste the full service account JSON as a single line, or point to a file path.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative: path to the service account file instead of inlining JSON
FIREBASE_SERVICE_ACCOUNT_PATH=

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxx

# VTpass
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
# Sandbox while testing; switch to https://vtpass.com/api for production
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
